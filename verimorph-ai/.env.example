# ============================================================
# VeriDoc AI — Environment Variables
# Copy this file to .env and fill in your actual API keys
# ============================================================

# Tavily Search API (for live web search and suggested question answers)
VITE_TAVILY_API_KEY=YOUR_API_KEY_HERE

# Groq API (for LLM inference and PDF reading)
VITE_GROQ_API_KEY=YOUR_API_KEY_HERE

# DeepSeek API (alternative LLM model)
VITE_DEEPSEEK_API_KEY=YOUR_API_KEY_HERE

# Supabase (for chat history and user session persistence)
VITE_SUPABASE_URL=YOUR_API_KEY_HERE
VITE_SUPABASE_KEY=YOUR_API_KEY_HERE

# Backend server
VITE_API_BASE_URL=http://localhost:8000
